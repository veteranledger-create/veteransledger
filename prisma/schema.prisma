generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String   @default("VIEWER")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  auditLogs  AuditLog[]
  mediaAssets MediaAsset[]

  // Community System (reserved) — this User is CMS/staff auth, distinct from
  // CommunityMember (the future public commenter/poster identity). These two
  // relations exist only because an admin reviews reports / performs
  // moderation actions; see the Community System block below.
  reviewedReports    CommunityReport[]
  moderationActions  CommunityModerationAction[]

  @@map("users")
}

model Collection {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?
  category    String
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  records Record[]

  @@map("collections")
}

model Record {
  id           String      @id @default(cuid())
  collectionId String?
  type         String
  title        String
  slug         String?     @unique
  summary      String?
  content      String?
  date         DateTime?
  startDate    DateTime?
  endDate      DateTime?
  location     String?
  nationality  String?
  metadata     Json?
  tags         String[]
  published    Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  collection Collection?  @relation(fields: [collectionId], references: [id])
  citations  Citation[]
  media      MediaAsset[] @relation("RecordMedia")

  @@index([type])
  @@index([type, published])
  @@index([createdAt])
  @@map("records")
}

model Entity {
  id          String   @id @default(cuid())
  type        String
  name        String
  slug        String?  @unique
  nationality String?
  birthDate   DateTime?
  deathDate   DateTime?
  summary     String?
  biography   String?
  metadata    Json?
  tags        String[]
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  aliases      EntityAlias[]
  relationsFrom Relationship[] @relation("RelationFrom")
  relationsTo   Relationship[] @relation("RelationTo")
  citations     Citation[]
  media         MediaAsset[]   @relation("EntityMedia")

  @@index([type])
  @@index([type, published])
  @@map("entities")
}

model EntityAlias {
  id       String @id @default(cuid())
  entityId String
  alias    String
  language String?

  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@map("entity_aliases")
}

model Relationship {
  id         String   @id @default(cuid())
  fromId     String
  toId       String
  type       String
  metadata   Json?
  createdAt  DateTime @default(now())

  from Entity @relation("RelationFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to   Entity @relation("RelationTo",   fields: [toId],   references: [id], onDelete: Cascade)

  @@map("relationships")
}

model TimelineEvent {
  id           String    @id @default(cuid())
  year         Int?
  date         DateTime?
  endDate      DateTime?
  title        String
  summary      String?
  category     String?
  location     String?
  significance String?
  metadata     Json?
  published    Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("timeline_events")
}

model Source {
  id        String   @id @default(cuid())
  title     String
  author    String?
  year      Int?
  publisher String?
  url       String?
  type      String
  notes     String?
  createdAt DateTime @default(now())

  citations Citation[]

  @@map("sources")
}

model Citation {
  id       String  @id @default(cuid())
  sourceId String
  recordId String?
  entityId String?
  page     String?
  notes    String?

  source Source  @relation(fields: [sourceId], references: [id])
  record Record? @relation(fields: [recordId], references: [id], onDelete: Cascade)
  entity Entity? @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@map("citations")
}

model MediaAsset {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  mimeType     String
  size         Int
  path         String
  url          String
  thumbnailUrl String?
  alt          String?
  caption      String?
  uploadedById String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  uploadedBy User     @relation(fields: [uploadedById], references: [id])
  records    Record[] @relation("RecordMedia")
  entities   Entity[] @relation("EntityMedia")

  @@map("media_assets")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Translation {
  id          String    @id @default(cuid())
  entityType  String    // "record" | "entity" | "timeline_event" | "site_content"
  entityId    String    // PK of the source record, or site-content key
  locale      String    // "de" | "ja" | "it" | "ru" | "es" | "fr" | "uk" | "ar" (English is the source, never stored here)
  status      String    @default("machine") // "machine" | "human" | "published"
  fields      Json      // { title?, summary?, content?, biography?, name? }
  generatedAt DateTime?
  verifiedAt  DateTime?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([entityType, entityId, locale])
  @@index([entityType, entityId])
  @@index([locale, status])
  @@map("translations")
}

model PreservationRecord {
  id          String   @id @default(cuid())
  entityType  String
  entityId    String
  checksum    String
  algorithm   String   @default("sha256")
  verifiedAt  DateTime @default(now())
  status      String   @default("VALID")
  notes       String?
  createdAt   DateTime @default(now())

  @@map("preservation_records")
}

// ═══════════════════════════════════════════════════════════════════════
// Community System — reserved foundation (Production Architecture phase).
//
// Nothing above this line is touched. Posts/Comments/Reactions/Reports/
// Notifications/Moderation are schema-only right now — no route builds on
// them yet (see src/modules/community and docs/community-architecture.md).
//
// CommunityMember is a deliberately separate identity from User: User is
// CMS/staff auth (role VIEWER/ADMIN/SUPER_ADMIN); CommunityMember is the
// future public-facing commenter/poster identity and has no auth wiring yet.
//
// A post/comment attaches to an archive record via the same generic
// entityType/entityId string-pair convention already used by Translation
// and PreservationRecord above — this is what lets "every archive record"
// support future discussion with zero schema changes to Record/Entity/
// TimelineEvent, and zero changes to their existing modules.
// ═══════════════════════════════════════════════════════════════════════

model CommunityMember {
  id          String   @id @default(cuid())
  displayName String
  email       String?  @unique
  avatarUrl   String?
  bio         String?
  status      String   @default("ACTIVE") // "ACTIVE" | "SUSPENDED" | "BANNED"
  reputation  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts         CommunityPost[]
  comments      CommunityComment[]
  reactions     CommunityReaction[]
  reportsFiled  CommunityReport[]       @relation("ReportsFiled")
  notifications CommunityNotification[]

  @@map("community_members")
}

model CommunityPost {
  id         String   @id @default(cuid())
  authorId   String
  entityType String?  // "record" | "entity" | "timeline_event" — null = freestanding post
  entityId   String?
  title      String?
  body       String
  status     String   @default("PUBLISHED") // "PUBLISHED" | "HIDDEN" | "DELETED"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  author   CommunityMember    @relation(fields: [authorId], references: [id])
  comments CommunityComment[]

  @@index([entityType, entityId])
  @@index([authorId])
  @@index([status])
  @@map("community_posts")
}

model CommunityComment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  parentId  String?  // set => reply to another comment, unifying comments+replies in one model
  body      String
  status    String   @default("PUBLISHED") // "PUBLISHED" | "HIDDEN" | "DELETED"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post    CommunityPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  CommunityMember    @relation(fields: [authorId], references: [id])
  parent  CommunityComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies CommunityComment[] @relation("CommentReplies")

  @@index([postId])
  @@index([parentId])
  @@index([authorId])
  @@map("community_comments")
}

model CommunityReaction {
  id         String   @id @default(cuid())
  memberId   String
  targetType String   // "POST" | "COMMENT"
  targetId   String
  type       String   // "HELPFUL" | "INFORMATIVE" | "WELL_RESEARCHED" | "NEEDS_VERIFICATION"
  createdAt  DateTime @default(now())

  member CommunityMember @relation(fields: [memberId], references: [id])

  @@unique([memberId, targetType, targetId, type])
  @@index([targetType, targetId])
  @@map("community_reactions")
}

model CommunityReport {
  id           String    @id @default(cuid())
  reporterId   String
  targetType   String    // "POST" | "COMMENT" | "MEMBER"
  targetId     String
  reason       String    // "SPAM" | "FLOODING" | "BOT" | "PROMOTIONAL" | "ADVERTISING" |
                          // "MALICIOUS_LINK" | "FALSE_ACCUSATION" | "HARASSMENT" | "IMPERSONATION" | "OTHER"
  details      String?
  status       String    @default("PENDING") // "PENDING" | "REVIEWED" | "DISMISSED" | "ACTIONED"
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime  @default(now())

  reporter   CommunityMember @relation("ReportsFiled", fields: [reporterId], references: [id])
  reviewedBy User?           @relation(fields: [reviewedById], references: [id])

  @@index([targetType, targetId])
  @@index([status])
  @@map("community_reports")
}

model CommunityModerationAction {
  id          String   @id @default(cuid())
  moderatorId String
  targetType  String   // "POST" | "COMMENT" | "MEMBER"
  targetId    String
  action      String   // "HIDE" | "RESTORE" | "DELETE" | "WARN_MEMBER" | "SUSPEND_MEMBER" | "BAN_MEMBER"
  reason      String?
  createdAt   DateTime @default(now())

  moderator User @relation(fields: [moderatorId], references: [id])

  @@index([targetType, targetId])
  @@index([moderatorId])
  @@map("community_moderation_actions")
}

model CommunityNotification {
  id        String   @id @default(cuid())
  memberId  String
  type      String   // "REPLY" | "MENTION" | "COMMENT_APPROVED" | "REPORT_UPDATE"
  payload   Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  member CommunityMember @relation(fields: [memberId], references: [id])

  @@index([memberId, read])
  @@map("community_notifications")
}
