# ── Server ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=localhost

# ── Database (PostgreSQL) ────────────────────────────────────────────────
DATABASE_URL="postgresql://veteransledger:password@localhost:5432/veteransledger?schema=public"

# ── Redis ────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Session ──────────────────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-long-random-secret-at-least-64-chars
SESSION_MAX_AGE=86400000

# ── JWT ──────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-different-long-random-secret
JWT_EXPIRES_IN=7d

# ── Admin ────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@veteransledger.com
ADMIN_PASSWORD=change-me-in-production

# ── Email (SMTP) ─────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=support@veteransledger.com
SMTP_PASS=your-smtp-password
SMTP_FROM="VeteransLedger Archive <support@veteransledger.com>"

# ── Storage ──────────────────────────────────────────────────────────────
STORAGE_PATH=./storage
MAX_FILE_SIZE=52428800

# ── CORS ─────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── Rate Limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
